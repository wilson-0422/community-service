<%- include('../layout', { title: '提交诉求', body: `
<div class="page-header">
  <h2>📋 提交民情诉求</h2>
  <a href="/complaints" class="btn btn-outline">返回列表</a>
</div>
${typeof error !== 'undefined' && error ? '<div class="alert alert-error">' + error + '</div>' : ''}
<form action="/complaints/create" method="POST" class="form-card">
  <div class="form-group">
    <label for="title">诉求标题 <span class="required">*</span></label>
    <input type="text" id="title" name="title" required placeholder="请输入诉求标题">
  </div>
  <div class="form-group">
    <label for="category">诉求分类 <span class="required">*</span></label>
    <select id="category" name="category" required>
      <option value="">请选择分类</option>
      <option value="基础设施">基础设施</option>
      <option value="环境卫生">环境卫生</option>
      <option value="噪音污染">噪音污染</option>
      <option value="安全管理">安全管理</option>
      <option value="物业服务">物业服务</option>
      <option value="邻里纠纷">邻里纠纷</option>
      <option value="其他">其他</option>
    </select>
  </div>
  <div class="form-group">
    <label for="priority">优先级</label>
    <select id="priority" name="priority">
      <option value="low">低</option>
      <option value="normal" selected>一般</option>
      <option value="high">重要</option>
      <option value="urgent">紧急</option>
    </select>
  </div>
  <div class="form-group">
    <label for="content">诉求内容 <span class="required">*</span></label>
    <textarea id="content" name="content" rows="6" required placeholder="请详细描述您的诉求"></textarea>
  </div>
  <button type="submit" class="btn btn-primary">提交诉求</button>
</form>
` }) %>
