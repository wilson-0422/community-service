<%- include('../layout', { title: complaint.title, body: `
<div class="page-header">
  <h2>📋 <%= complaint.title %></h2>
  <a href="/complaints" class="btn btn-outline">返回列表</a>
</div>
<div class="detail-card">
  <div class="detail-row">
    <span class="detail-label">诉求编号</span>
    <span>#<%= complaint.id %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">诉求分类</span>
    <span><%= complaint.category %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">优先级</span>
    <span class="badge <%= complaint.priority === 'urgent' ? 'badge-danger' : complaint.priority === 'high' ? 'badge-warning' : complaint.priority === 'normal' ? 'badge-info' : 'badge-success' %>">
      <%= complaint.priority === 'urgent' ? '紧急' : complaint.priority === 'high' ? '重要' : complaint.priority === 'normal' ? '一般' : '低' %>
    </span>
  </div>
  <div class="detail-row">
    <span class="detail-label">当前状态</span>
    <span class="badge <%= complaint.status === 'pending' ? 'badge-warning' : complaint.status === 'processing' ? 'badge-info' : complaint.status === 'resolved' ? 'badge-success' : 'badge-danger' %>">
      <%= complaint.status === 'pending' ? '待处理' : complaint.status === 'processing' ? '处理中' : complaint.status === 'resolved' ? '已回复' : '已关闭' %>
    </span>
  </div>
  <div class="detail-row">
    <span class="detail-label">提交人</span>
    <span><%= complaint.submitter_name || '-' %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">提交时间</span>
    <span><%= complaint.created_at %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">诉求内容</span>
    <p><%= complaint.content %></p>
  </div>
  <% if (complaint.reply) { %>
  <div class="detail-row">
    <span class="detail-label">处理回复</span>
    <div class="reply-box">
      <p><%= complaint.reply %></p>
      <span class="meta">回复人：<%= complaint.handler_name || '-' %> | 更新时间：<%= complaint.updated_at %></span>
    </div>
  </div>
  <% } %>
</div>
<% if (role === 'admin') { %>
<div class="section" style="margin-top: 2rem">
  <h3>管理操作</h3>
  <div class="admin-actions">
    <form action="/complaints/<%= complaint.id %>/status" method="POST" style="display:inline">
      <select name="status">
        <option value="processing" <%= complaint.status === 'processing' ? 'selected' : '' %>>处理中</option>
        <option value="resolved" <%= complaint.status === 'resolved' ? 'selected' : '' %>>已回复</option>
        <option value="closed" <%= complaint.status === 'closed' ? 'selected' : '' %>>已关闭</option>
      </select>
      <button type="submit" class="btn btn-sm btn-primary">更新状态</button>
    </form>
  </div>
  <form action="/complaints/<%= complaint.id %>/reply" method="POST" class="form-card" style="margin-top: 1rem">
    <div class="form-group">
      <label for="reply">回复内容</label>
      <textarea id="reply" name="reply" rows="4" placeholder="请输入回复内容"></textarea>
    </div>
    <button type="submit" class="btn btn-primary">提交回复</button>
  </form>
</div>
<% } %>
` }) %>
