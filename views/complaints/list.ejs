<%- include('../layout', { title: '民情诉求', body: `
<div class="page-header">
  <h2>📋 民情诉求台账</h2>
  <a href="/complaints/create" class="btn btn-primary">提交诉求</a>
</div>
<table class="table">
  <thead>
    <tr>
      <th>编号</th>
      <th>标题</th>
      <th>分类</th>
      <th>优先级</th>
      <th>状态</th>
      <th>提交人</th>
      <th>提交时间</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% complaints.forEach(function(c) { %>
    <tr>
      <td><%= c.id %></td>
      <td><a href="/complaints/<%= c.id %>"><%= c.title %></a></td>
      <td><%= c.category %></td>
      <td>
        <span class="badge <%= c.priority === 'urgent' ? 'badge-danger' : c.priority === 'high' ? 'badge-warning' : c.priority === 'normal' ? 'badge-info' : 'badge-success' %>">
          <%= c.priority === 'urgent' ? '紧急' : c.priority === 'high' ? '重要' : c.priority === 'normal' ? '一般' : '低' %>
        </span>
      </td>
      <td>
        <span class="badge <%= c.status === 'pending' ? 'badge-warning' : c.status === 'processing' ? 'badge-info' : c.status === 'resolved' ? 'badge-success' : 'badge-danger' %>">
          <%= c.status === 'pending' ? '待处理' : c.status === 'processing' ? '处理中' : c.status === 'resolved' ? '已回复' : '已关闭' %>
        </span>
      </td>
      <td><%= c.submitter_name || '-' %></td>
      <td><%= c.created_at %></td>
      <td><a href="/complaints/<%= c.id %>" class="btn btn-sm btn-outline">查看</a></td>
    </tr>
    <% }) %>
    <% if (complaints.length === 0) { %>
    <tr><td colspan="8" class="empty">暂无诉求</td></tr>
    <% } %>
  </tbody>
</table>
` }) %>
