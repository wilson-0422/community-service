<%- include('../layout', { title: item.title, body: `
<div class="page-header">
  <h2>♻️ <%= item.title %></h2>
  <a href="/exchanges" class="btn btn-outline">返回列表</a>
</div>
<div class="detail-card">
  <div class="detail-row">
    <span class="detail-label">物品状态</span>
    <span class="badge <%= item.status === 'available' ? 'badge-success' : item.status === 'exchanged' ? 'badge-info' : 'badge-danger' %>">
      <%= item.status === 'available' ? '可置换' : item.status === 'exchanged' ? '已置换' : '已下架' %>
    </span>
  </div>
  <div class="detail-row">
    <span class="detail-label">物品分类</span>
    <span>📂 <%= item.category %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">物品成色</span>
    <span>✨ <%= item.condition_level === 'new' ? '全新' : item.condition_level === 'good' ? '良好' : '一般' %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">物品描述</span>
    <p><%= item.description || '暂无描述' %></p>
  </div>
  <div class="detail-row">
    <span class="detail-label">发布人</span>
    <span>👤 <%= item.owner_name %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">联系方式</span>
    <span>📞 <%= item.contact_info || '未提供' %></span>
  </div>
  <div class="detail-row">
    <span class="detail-label">发布时间</span>
    <span>🕐 <%= item.created_at %></span>
  </div>
  <div class="detail-actions">
    <% if (item.status === 'available') { %>
      <form action="/exchanges/<%= item.id %>/exchange" method="POST" style="display:inline">
        <button type="submit" class="btn btn-primary" onclick="return confirm('确认标记为已置换？')">标记已置换</button>
      </form>
      <form action="/exchanges/<%= item.id %>/remove" method="POST" style="display:inline">
        <button type="submit" class="btn btn-danger" onclick="return confirm('确认下架此物品？')">下架</button>
      </form>
    <% } %>
  </div>
</div>
` }) %>
