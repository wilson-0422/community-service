<%- include('../layout', { title: '志愿者排班', body: `
<div class="page-header">
  <h2>🤝 志愿者排班</h2>
  <% if (role === 'admin') { %>
  <button type="button" class="btn btn-primary" onclick="document.getElementById('newShiftForm').style.display='block'">新增排班</button>
  <% } %>
</div>
<% if (role === 'admin') { %>
<div id="newShiftForm" style="display:none" class="form-card">
  <h3>新增志愿排班</h3>
  <form action="/volunteers/create" method="POST">
    <div class="form-group">
      <label for="title">任务名称 <span class="required">*</span></label>
      <input type="text" id="title" name="title" required placeholder="请输入任务名称">
    </div>
    <div class="form-group">
      <label for="description">任务描述</label>
      <textarea id="description" name="description" rows="3" placeholder="请输入任务描述"></textarea>
    </div>
    <div class="form-group">
      <label for="location">服务地点 <span class="required">*</span></label>
      <input type="text" id="location" name="location" required placeholder="请输入服务地点">
    </div>
    <div class="form-group">
      <label for="shift_date">服务日期 <span class="required">*</span></label>
      <input type="date" id="shift_date" name="shift_date" required>
    </div>
    <div class="form-row">
      <div class="form-group">
        <label for="start_time">开始时间 <span class="required">*</span></label>
        <input type="time" id="start_time" name="start_time" required>
      </div>
      <div class="form-group">
        <label for="end_time">结束时间 <span class="required">*</span></label>
        <input type="time" id="end_time" name="end_time" required>
      </div>
    </div>
    <div class="form-group">
      <label for="max_volunteers">最大志愿者人数</label>
      <input type="number" id="max_volunteers" name="max_volunteers" value="5" min="1">
    </div>
    <button type="submit" class="btn btn-primary">创建排班</button>
    <button type="button" class="btn btn-outline" onclick="document.getElementById('newShiftForm').style.display='none'">取消</button>
  </form>
</div>
<% } %>
<table class="table">
  <thead>
    <tr>
      <th>任务名称</th>
      <th>服务地点</th>
      <th>服务日期</th>
      <th>服务时间</th>
      <th>志愿者人数</th>
      <th>状态</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% shifts.forEach(function(shift) { %>
    <tr>
      <td><a href="/volunteers/<%= shift.id %>"><%= shift.title %></a></td>
      <td><%= shift.location %></td>
      <td><%= shift.shift_date %></td>
      <td><%= shift.start_time %> ~ <%= shift.end_time %></td>
      <td><%= shift.current_volunteers %>/<%= shift.max_volunteers %></td>
      <td>
        <span class="badge <%= shift.status === 'open' ? 'badge-success' : 'badge-warning' %>">
          <%= shift.status === 'open' ? '招募中' : '已满员' %>
        </span>
      </td>
      <td>
        <% if (signedUpIds.has(shift.id)) { %>
          <form action="/volunteers/<%= shift.id %>/cancel" method="POST" style="display:inline">
            <button type="submit" class="btn btn-sm btn-warning">取消报名</button>
          </form>
        <% } else if (shift.status === 'open') { %>
          <form action="/volunteers/<%= shift.id %>/signup" method="POST" style="display:inline">
            <button type="submit" class="btn btn-sm btn-primary">报名参加</button>
          </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
    <% if (shifts.length === 0) { %>
    <tr><td colspan="7" class="empty">暂无排班</td></tr>
    <% } %>
  </tbody>
</table>
` }) %>
