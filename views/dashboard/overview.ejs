<%- include('../layout', { title: '平台概览', body: `
<div class="page-header">
  <h2>📊 平台概览</h2>
</div>
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon">🎉</div>
    <div class="stat-value"><%= stats.activityCount %></div>
    <div class="stat-label">邻里活动</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🍽️</div>
    <div class="stat-value"><%= stats.mealOrderCount %></div>
    <div class="stat-label">助餐订单</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">♻️</div>
    <div class="stat-value"><%= stats.exchangeItemCount %></div>
    <div class="stat-label">闲置物品</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">🤝</div>
    <div class="stat-value"><%= stats.volunteerShiftCount %></div>
    <div class="stat-label">志愿排班</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">👤</div>
    <div class="stat-value"><%= stats.userCount %></div>
    <div class="stat-label">注册用户</div>
  </div>
  <div class="stat-card">
    <div class="stat-icon">📋</div>
    <div class="stat-value"><%= stats.total %></div>
    <div class="stat-label">民情诉求</div>
  </div>
</div>
<div class="dashboard-row">
  <div class="dashboard-section">
    <h3>🎉 最新活动</h3>
    <table class="table">
      <thead>
        <tr><th>活动名称</th><th>时间</th><th>状态</th></tr>
      </thead>
      <tbody>
        <% recentActivities.forEach(function(a) { %>
        <tr>
          <td><a href="/activities/<%= a.id %>"><%= a.title %></a></td>
          <td><%= a.start_time %></td>
          <td><span class="badge <%= a.status === 'open' ? 'badge-success' : 'badge-warning' %>"><%= a.status === 'open' ? '报名中' : '已满员' %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <div class="dashboard-section">
    <h3>📋 最新诉求</h3>
    <table class="table">
      <thead>
        <tr><th>标题</th><th>分类</th><th>状态</th></tr>
      </thead>
      <tbody>
        <% recentComplaints.forEach(function(c) { %>
        <tr>
          <td><a href="/complaints/<%= c.id %>"><%= c.title %></a></td>
          <td><%= c.category %></td>
          <td><span class="badge <%= c.status === 'pending' ? 'badge-warning' : c.status === 'processing' ? 'badge-info' : 'badge-success' %>"><%= c.status === 'pending' ? '待处理' : c.status === 'processing' ? '处理中' : '已回复' %></span></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<div class="complaint-stats" style="margin-top: 2rem">
  <h3>📋 诉求处理统计</h3>
  <div class="stats-grid">
    <div class="stat-card stat-small">
      <div class="stat-value"><%= stats.pending %></div>
      <div class="stat-label">待处理</div>
    </div>
    <div class="stat-card stat-small">
      <div class="stat-value"><%= stats.processing %></div>
      <div class="stat-label">处理中</div>
    </div>
    <div class="stat-card stat-small">
      <div class="stat-value"><%= stats.resolved %></div>
      <div class="stat-label">已回复</div>
    </div>
  </div>
</div>
` }) %>
