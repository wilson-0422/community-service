<%- include('../layout', { title: '我的订单', body: `
<div class="page-header">
  <h2>🍽️ 助餐订单</h2>
  <a href="/meals/order" class="btn btn-primary">预约订餐</a>
</div>
<table class="table">
  <thead>
    <tr>
      <th>订单号</th>
      <th>用餐日期</th>
      <th>用餐类型</th>
      <th>菜品</th>
      <th>状态</th>
      <th>下单时间</th>
      <th>操作</th>
    </tr>
  </thead>
  <tbody>
    <% orders.forEach(function(order) { %>
    <tr>
      <td><%= order.id %></td>
      <td><%= order.meal_date %></td>
      <td><%= order.meal_type === 'breakfast' ? '早餐' : order.meal_type === 'lunch' ? '午餐' : '晚餐' %></td>
      <td><%= order.menu_item %></td>
      <td>
        <span class="badge <%= order.status === 'pending' ? 'badge-warning' : order.status === 'confirmed' ? 'badge-success' : 'badge-danger' %>">
          <%= order.status === 'pending' ? '待确认' : order.status === 'confirmed' ? '已确认' : '已取消' %>
        </span>
      </td>
      <td><%= order.created_at %></td>
      <td>
        <% if (order.status === 'pending') { %>
          <form action="/meals/<%= order.id %>/cancel" method="POST" style="display:inline">
            <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('确定取消此订单？')">取消</button>
          </form>
        <% } %>
      </td>
    </tr>
    <% }) %>
    <% if (orders.length === 0) { %>
    <tr><td colspan="7" class="empty">暂无订单</td></tr>
    <% } %>
  </tbody>
</table>
` }) %>
