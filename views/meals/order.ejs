<%- include('../layout', { title: '预约订餐', body: `
<div class="page-header">
  <h2>🍽️ 预约订餐</h2>
  <a href="/meals" class="btn btn-outline">返回菜单</a>
</div>
${typeof error !== 'undefined' && error ? '<div class="alert alert-error">' + error + '</div>' : ''}
<form action="/meals/order" method="POST" class="form-card">
  <div class="form-group">
    <label for="meal_date">用餐日期 <span class="required">*</span></label>
    <input type="date" id="meal_date" name="meal_date" required>
  </div>
  <div class="form-group">
    <label for="meal_type">用餐类型 <span class="required">*</span></label>
    <select id="meal_type" name="meal_type" required>
      <option value="">请选择</option>
      <option value="breakfast">🌅 早餐</option>
      <option value="lunch">☀️ 午餐</option>
      <option value="dinner">🌙 晚餐</option>
    </select>
  </div>
  <div class="form-group">
    <label for="menu_item">选择菜品 <span class="required">*</span></label>
    <select id="menu_item" name="menu_item" required>
      <option value="">请先选择用餐类型</option>
    </select>
  </div>
  <button type="submit" class="btn btn-primary">提交预约</button>
</form>
<script>
  var menuItems = <%- JSON.stringify(menuItems) %>;
  document.getElementById('meal_type').addEventListener('change', function() {
    var type = this.value;
    var select = document.getElementById('menu_item');
    select.innerHTML = '<option value="">请选择菜品</option>';
    if (type && menuItems[type]) {
      menuItems[type].forEach(function(item) {
        var opt = document.createElement('option');
        opt.value = item;
        opt.textContent = item;
        select.appendChild(opt);
      });
    }
  });
</script>
` }) %>
